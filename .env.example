# Facebook Graph API
FB_ACCESS_TOKEN=your_long_lived_page_access_token
FB_FORM_ID=your_lead_gen_form_id

# Gmail SMTP (use an App Password, not your main password)
# Enable 2FA → Google Account → Security → App Passwords → generate one
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# Where to send the notification email
NOTIFY_EMAIL=you@gmail.com

# Close CRM
CLOSE_API_KEY=your_close_api_key
